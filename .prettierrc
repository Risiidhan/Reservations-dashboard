{
  "semi": true,
  "printWidth": 80,
  "singleQuote": false,
  "bracketSameLine": true,
  "htmlWhitespaceSensitivity": "strict",
  "jsxSingleQuote": false,
  "bracketSpacing": true,
  "trailingComma": "all",
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindStylesheet": "./src/app/globals.css"
}
